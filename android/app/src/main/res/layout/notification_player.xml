<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/notif_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/notification_bg"
    android:orientation="vertical">

    <!-- Accent gradient bar at top -->
    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="@drawable/notif_accent_bar"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="14dp">

        <!-- Top row: icon + song info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/notif_artwork"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:scaleType="centerCrop"
                android:background="@drawable/notif_art_bg"
                android:src="@mipmap/ic_launcher"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="8dp">

                <TextView
                    android:id="@+id/notif_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="BoxOfVibe"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/notif_artist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="BoxOfVibe"
                    android:textColor="#E879F9"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="3dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Bottom row: Sleep · Prev · Play · Next · Repeat · Like -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:weightSum="6">

            <!-- Sleep Timer -->
            <ImageView
                android:id="@+id/notif_sleep"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:src="@drawable/ic_moon"
                android:padding="7dp"
                android:scaleType="fitCenter"/>

            <!-- Prev -->
            <ImageView
                android:id="@+id/notif_prev"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:src="@drawable/ic_skip_prev"
                android:padding="6dp"
                android:scaleType="fitCenter"/>

            <!-- Play/Pause -->
            <ImageView
                android:id="@+id/notif_play"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:src="@drawable/ic_play"
                android:padding="10dp"
                android:background="@drawable/notif_play_bg"
                android:scaleType="fitCenter"/>

            <!-- Next -->
            <ImageView
                android:id="@+id/notif_next"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:src="@drawable/ic_skip_next"
                android:padding="6dp"
                android:scaleType="fitCenter"/>

            <!-- Repeat -->
            <ImageView
                android:id="@+id/notif_repeat"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:src="@drawable/ic_repeat"
                android:padding="7dp"
                android:scaleType="fitCenter"/>

            <!-- Like -->
            <ImageView
                android:id="@+id/notif_like"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:src="@drawable/ic_heart"
                android:padding="7dp"
                android:scaleType="fitCenter"/>

        </LinearLayout>
    </LinearLayout>

</LinearLayout>
