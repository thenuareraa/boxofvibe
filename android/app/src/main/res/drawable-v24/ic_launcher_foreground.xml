<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon foreground — 108dp canvas, safe zone = center 72dp (r≤36 from 54,54).
  Matches the in-app logo: dark vinyl with purple→pink→orange gradient border ring + shine bar.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Soft glow behind vinyl (r=36) -->
    <path android:pathData="M54,54 m-36,0 a36,36,0,1,0,72,0 a36,36,0,1,0,-72,0"
        android:fillAlpha="0.6">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial"
                android:centerX="54" android:centerY="54"
                android:gradientRadius="36">
                <item android:offset="0.0" android:color="#4DA855F7"/>
                <item android:offset="0.5" android:color="#33EC4899"/>
                <item android:offset="1.0" android:color="#00FB923C"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Gradient border ring purple→pink→orange (r=35) -->
    <path android:pathData="M54,54 m-35,0 a35,35,0,1,0,70,0 a35,35,0,1,0,-70,0">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="19" android:startY="19"
                android:endX="89" android:endY="89">
                <item android:offset="0.0" android:color="#99A855F7"/>
                <item android:offset="0.5" android:color="#99EC4899"/>
                <item android:offset="1.0" android:color="#99FB923C"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Vinyl disc body (r=33) -->
    <path android:pathData="M54,54 m-33,0 a33,33,0,1,0,66,0 a33,33,0,1,0,-66,0">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial"
                android:centerX="54" android:centerY="54"
                android:gradientRadius="33">
                <item android:offset="0.0" android:color="#FF4a4a4a"/>
                <item android:offset="0.7" android:color="#FF2a2a2a"/>
                <item android:offset="1.0" android:color="#FF1a1a1a"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Groove rings r=29/25/21/17 -->
    <path android:pathData="M54,54 m-29,0 a29,29,0,1,0,58,0 a29,29,0,1,0,-58,0"
        android:fillColor="#00000000" android:strokeColor="#203a3a3a" android:strokeWidth="0.5"/>
    <path android:pathData="M54,54 m-25,0 a25,25,0,1,0,50,0 a25,25,0,1,0,-50,0"
        android:fillColor="#00000000" android:strokeColor="#203a3a3a" android:strokeWidth="0.5"/>
    <path android:pathData="M54,54 m-21,0 a21,21,0,1,0,42,0 a21,21,0,1,0,-42,0"
        android:fillColor="#00000000" android:strokeColor="#203a3a3a" android:strokeWidth="0.5"/>
    <path android:pathData="M54,54 m-17,0 a17,17,0,1,0,34,0 a17,17,0,1,0,-34,0"
        android:fillColor="#00000000" android:strokeColor="#203a3a3a" android:strokeWidth="0.5"/>

    <!-- Centre label purple→pink→orange (r=13) -->
    <path android:pathData="M54,54 m-13,0 a13,13,0,1,0,26,0 a13,13,0,1,0,-26,0">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="41" android:startY="41"
                android:endX="67" android:endY="67">
                <item android:offset="0.0" android:color="#FFA855F7"/>
                <item android:offset="0.5" android:color="#FFEC4899"/>
                <item android:offset="1.0" android:color="#FFFB923C"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Shine bar (matches in-app logo, spans vinyl height) -->
    <path android:pathData="M49,19 L49,89 Q49,89 54,89 L59,89 L59,19 Q59,19 54,19 Z"
        android:fillAlpha="0.15">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="49" android:startY="54"
                android:endX="59" android:endY="54">
                <item android:offset="0.0" android:color="#00ffffff"/>
                <item android:offset="0.5" android:color="#FFffffff"/>
                <item android:offset="1.0" android:color="#00ffffff"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Centre hole (r=3) -->
    <path android:pathData="M54,54 m-3,0 a3,3,0,1,0,6,0 a3,3,0,1,0,-6,0"
        android:fillColor="#1a1a1a"/>

</vector>
